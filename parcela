<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
<h2>Calculadora</h2>

<form onsubmit="calcular(event)">
    <input type="number" id="preco" placeholder="Preço" required><br><br>

    <select id="parcelas">
        <option value="1">1x</option>
        <option value="3">3x</option>
        <option value="5">5x</option>
    </select><br><br>

    <button type="submit">Calcular</button>
</form>

<div id="resultado"></div>

<script>
function calcular(event){
    event.preventDefault();

    let preco = Number(document.getElementById("preco").value);
    let parcelas = Number(document.getElementById("parcelas").value);

    let total = preco;

    if(parcelas === 3){
        total = preco * 1.10;
    } else if(parcelas === 5){
        total = preco * 1.20;
    }

    let valor = total / parcelas;

    document.getElementById("resultado").innerHTML +=
        "Total: R$ " + total.toFixed(2) + "<br>" +
        "Parcela: R$ " + valor.toFixed(2) + "<br><hr>";
}
</script>

</body>
</html>